# Copy to .env and fill in values

# LLM backend: "api" (Anthropic) or "local" (Ollama)
LLM_MODE=api

# Required if LLM_MODE=api
ANTHROPIC_API_KEY=sk-ant-...

# Required if LLM_MODE=local
OLLAMA_HOST=http://localhost:11434

# Optional: HuggingFace token for faster model downloads
HF_TOKEN=

# PDF extraction: "pymupdf" (fast) or "marker" (high quality, slow)
PDF_EXTRACTOR=pymupdf