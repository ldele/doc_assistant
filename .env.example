# Copy to .env and fill in values

# LLM backend: "api" (Anthropic) or "local" (Ollama)
LLM_MODE=api

# Required if LLM_MODE=api. Get one at https://console.anthropic.com/ (fee)
ANTHROPIC_API_KEY=sk-ant-...

# Required if LLM_MODE=local. Points to your Ollama server.
OLLAMA_HOST=http://localhost:11434

# Optional: HuggingFace token for faster model downloads https://huggingface.co/settings/tokens
HF_TOKEN=

# PDF extraction: "pymupdf" (fast) or "marker" (high quality, slow)
PDF_EXTRACTOR=pymupdf

# ===== Experiments (Finding best settings) =====
USE_PARENT_CHILD=true
USE_MULTI_QUERY=false
TOP_K=10