# ============================================================
# doc_assistant — environment variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only ANTHROPIC_API_KEY is required for default (API) mode.
# Everything else has sane defaults.
#
# NOTE: there is no TORCH_* / CUDA knob here. The PyTorch backend (CPU vs CUDA) is
# NOT an env var — it is chosen per machine at install time by a uv extra:
#   GPU box:  uv sync --extra cu130        CPU box / CI:  uv sync --extra cpu
# See README "Setup" and docs/specs/torch-backend-per-machine.md.
# ============================================================

# --- Required ---------------------------------------------------

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# --- LLM mode ---------------------------------------------------

# "api" (default) = Anthropic API  |  "local" = Ollama
# Back-compat shim: derives the analysis provider default below.
LLM_MODE=api

# Ollama host (used by any provider set to "ollama")
OLLAMA_HOST=http://localhost:11434

# --- LLM providers (Phase 6, Feature 1 — generation side) -------
# Two call shapes, configured independently:
#   * Analysis / chat (streaming)      → LLM_PROVIDER / LLM_MODEL
#   * Reviewer agent (one-shot JSON)   → REVIEWER_PROVIDER / REVIEWER_MODEL
#   * Eval LLM-judge (one-shot JSON)   → JUDGE_PROVIDER / JUDGE_MODEL
# Provider is "anthropic" or "ollama".
#
# The GENERATOR targets fully local; the JUDGE is a pinned measurement
# instrument — it defaults to a fixed reference model so cross-run numbers
# stay comparable, and moves to local only after the calibration gate
# passes (tests/eval/TESTING.md).
#
# REVIEWER pinning (ADR-011, desktop provider switch): with REVIEWER_PROVIDER
# unset, the reviewer FOLLOWS the live chat provider/model — including a
# switch made in the desktop Settings panel, and a custom LLM_MODEL set here.
# To keep the reviewer a fixed instrument, set REVIEWER_PROVIDER explicitly
# (then REVIEWER_MODEL applies); REVIEWER_MODEL alone is ignored while
# following.
#
# LLM_PROVIDER=anthropic            # default: anthropic if LLM_MODE=api, else ollama
# LLM_MODEL=claude-haiku-4-5-20251001   # ollama default: llama3
# REVIEWER_PROVIDER=anthropic       # default: same as LLM_PROVIDER
# REVIEWER_MODEL=claude-haiku-4-5-20251001
# JUDGE_PROVIDER=anthropic          # default: same as LLM_PROVIDER
# JUDGE_MODEL=claude-haiku-4-5-20251001

# --- Fully local (no Anthropic key needed) ----------------------
# Uncomment this block AND leave ANTHROPIC_API_KEY empty to run the
# generator and reviewer entirely on a local Ollama server. (The eval
# judge can also go local, but stays pinned until calibrated — see above.)
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3
#   REVIEWER_PROVIDER=ollama
#   REVIEWER_MODEL=llama3
#   EMBEDDING_MODEL=bge-base

# --- Enrichment generators (batch CLIs) — default to LOCAL, not paid ----
# The wiki summariser and concept-graph extractor are batch generators that
# run an LLM over many docs/clusters. Unlike the analysis provider, they
# default to LOCAL Ollama *explicitly* (NOT LLM_PROVIDER), so a `--apply` run
# is free by default even when the rest of your .env is all-Anthropic. Override
# only to opt into a paid run.
#   WIKI_LLM_PROVIDER=ollama          # default: ollama (was: inherit LLM_PROVIDER)
#   WIKI_LLM_MODEL=llama3
#   CONCEPT_GRAPH_LLM_PROVIDER=ollama # default: ollama
#   CONCEPT_GRAPH_LLM_MODEL=llama3.1:8b
#
# Cost guard: any enrichment `--apply` run that resolves to a PAID provider
# (anthropic) prints a loud cost banner + a Ctrl-C abort window before spending
# — it can never bill silently. In automation/CI, set DOC_ASSUME_YES=1 to skip
# only the pause (the banner still prints). Figure VLM description is
# Anthropic-only (no local path) and is guarded the same way.
#   DOC_ASSUME_YES=1
#
# Wiki clustering primitive (Feature 6 re-point). Off by default = absolute-cosine
# WIKI_MIN_SIMILARITY union-find (corpus-dependent; saturates on same-domain
# libraries). Set true to cluster by the Feature 7 concept-graph *communities*
# instead (threshold-free Louvain) — reads data/graph/graph.json, so run
# `python -m scripts.build_concept_graph --apply` first; falls back to cosine if
# that sidecar is absent or stale. Free either way (no LLM for clustering).
#   WIKI_USE_CONCEPT_COMMUNITIES=true

# Live 7d epistemics marker chips (contested / superseded-trend) on source cards.
# Default TRUE since the KI-7 retirement (the curated skeleton replaced the noisy
# open-vocabulary graph that motivated R7's off-default; this comment previously
# said "default off" — that was stale). This env var is only the BOTTOM layer of
# the ADR-027 D2 resolution (E3): the in-app Settings toggle ("Answer epistemics",
# persisted per install) overrides it, and the per-turn RAG-sandbox override (U1b)
# wins over both for the session. Governs the answer-surface chips only — the
# per-source evaluation strip (D3) is always-on regardless.
#   EPISTEMICS_MARKERS_ENABLED=true

# Concept-skeleton presence match (R2). "boundary" (default) = whole-word (alnum-
# bounded) so "bert" doesn't fire inside "sbert"/"colbert"/"roberta"; "substring" =
# raw str.count, kept as the A/B lever for the RG-008 comparison run.
#   CONCEPT_SKELETON_PRESENCE_MODE=substring

# Gap-detection Tier-2a stochastic ceiling (`scripts/build_gaps.py --suggest`, SPRINT-005).
# Quarantined LLM suggestions over under-connected concepts — never written as fact.
# Defaults to LOCAL Ollama explicitly (not LLM_PROVIDER — the KI-4 credit-leak guard);
# `--provider anthropic` is opt-in and routes through the paid-run cost guard.
#   GAP_SUGGEST_LLM_PROVIDER=ollama    # default: ollama
#   GAP_SUGGEST_LLM_MODEL=llama3.1:8b

# --- Extraction --------------------------------------------------

# PDF extraction backend: "pymupdf" (default) or "marker"
PDF_EXTRACTOR=pymupdf

# --- HuggingFace -------------------------------------------------

# Optional. Speeds up model downloads. Read-only token is enough.
# https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Embedding model (Phase 5, Feature 1) -----------------------

# Active embedding model. Options:
#   bge-base  (default — BAAI/bge-base-en-v1.5, general English)
#   specter2  (allenai/specter2_base, academic papers / citation-graph trained)
#
# Switching to a new model points retrieval at a fresh, empty Chroma
# collection until you re-ingest. Plan for re-ingest when swapping.
EMBEDDING_MODEL=bge-base

# --- RAG tuning (locked — change only after running an experiment)

# Parent-child retrieval: true (default) | false
USE_PARENT_CHILD=true

# Multi-query expansion: true | false (default, regressed in testing)
USE_MULTI_QUERY=false

# Top-K candidates passed to reranker then LLM
TOP_K=10

# --- Synthesis mode (Phase 6 / Integrity Chunk 2a) ---------------
# ai (default) = dual-layer: deterministic evidence + a labelled AI
#                interpretation segmented into accept/reject/edit claims.
# human        = evidence (retrieved passages) only; the interpretation is
#                yours — the AI synthesis call is skipped.
SYNTHESIS_MODE=ai

# --- Chunking (config-driven; defaults are the historical hardcoded values)
# Unmeasured as of Phase 6 — sweep with scripts/sweep_chunking.py before
# changing. A size change invalidates the embedding cache (full re-ingest).
PARENT_CHUNK_SIZE=2000
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=50
BASELINE_CHUNK_SIZE=1000
BASELINE_CHUNK_OVERLAP=200
