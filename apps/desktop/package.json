{
  "name": "doc-assistant-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Tauri desktop frontend for doc_assistant — a thin Svelte UI over the FastAPI/SSE boundary (PR-M3). No business logic; renders the API's TurnResult payload.",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "preview": "vite preview --port 1420 --strictPort"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "marked": "^14.1.0"
  }
}
