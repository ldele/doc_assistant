{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "doc_assistant",
  "version": "0.1.0",
  "identifier": "com.doc-assistant.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "doc_assistant",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' http://127.0.0.1:8001 asset: data:; connect-src 'self' http://127.0.0.1:8001"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
